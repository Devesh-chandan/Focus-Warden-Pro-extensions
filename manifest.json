{
  "manifest_version": 3,
  "name": "Focus Warden Pro",
  "version": "2.1",
  "description": "Professional multi-tab focus protection with visual countdown.",
  "permissions": ["tabs", "storage", "scripting"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  }
}